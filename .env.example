# OpenRouteService API key (free tier) — register at openrouteservice.org
ORS_API_KEY=

# Storage: Upstash Redis (KV-compatible). Provision via the Vercel Marketplace.
# If unset, Flock falls back to a local file store (./.flock-data) for dev only.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Public app URL, e.g. https://getflock.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Log verbosity: debug | info | warn | error
FLOCK_LOG_LEVEL=debug
